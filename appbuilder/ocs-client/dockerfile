FROM node:22-alpine AS build

WORKDIR /app

ARG VITE_API_URL=/api/v1
ENV VITE_API_URL=${VITE_API_URL}

COPY ocs-client/package*.json ./
RUN npm ci

COPY ocs-client/index.html ./index.html
COPY ocs-client/src ./src

RUN npm run build

FROM nginx:1.27-alpine

COPY appbuilder/ocs-client/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
