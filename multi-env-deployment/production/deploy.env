COMPOSE_PROJECT_NAME=ocs-prod
HTTP_PORT=80
APP_PORT=3131

OCS_SERVICE_IMAGE=ocs-service:prod-latest
OCS_CLIENT_IMAGE=ocs-client:prod-latest
OCS_NGINX_REVERSE_PROXY_IMAGE=ocs-nginx-reverse-proxy-manager:prod-latest

OCS_SERVICE_CONTAINER=ocs-service-prod
OCS_CLIENT_CONTAINER=ocs-client-prod
OCS_NGINX_CONTAINER=ocs-nginx-reverse-proxy-manager-prod
OCS_NETWORK=ocs-prod-network

DB_USER=ocs_app
DB_PASS=change-me
DB_SERVER=host.docker.internal
DB_NAME=testing_production
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_INSTANCE=SQLEXPRESS
