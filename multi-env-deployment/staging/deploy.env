COMPOSE_PROJECT_NAME=ocs-stag
HTTP_PORT=8081
APP_PORT=3131

OCS_SERVICE_IMAGE=ocs-service:stag-latest
OCS_CLIENT_IMAGE=ocs-client:stag-latest
OCS_NGINX_REVERSE_PROXY_IMAGE=ocs-nginx-reverse-proxy-manager:stag-latest

OCS_SERVICE_CONTAINER=ocs-service-stag
OCS_CLIENT_CONTAINER=ocs-client-stag
OCS_NGINX_CONTAINER=ocs-nginx-reverse-proxy-manager-stag
